# =====================================================================
# theiosbogota.com — Required environment variables
# Copy to .env.local for development; set in Vercel for production.
# NEVER commit real values to git.
# =====================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://theiosbogota.com

# --- Bold (payment gateway) ---
# Public, exposed in client (used by Bold button widget)
NEXT_PUBLIC_BOLD_API_KEY=
NEXT_PUBLIC_BOLD_ENV=production
# Server-only — used to sign integrity hashes
BOLD_SECRET_KEY=
# Server-only — used to verify webhook signatures
# (configure in Bold dashboard → Webhooks → Secret)
BOLD_WEBHOOK_SECRET=

# --- Wompi (payment gateway) ---
# Server-only — used to verify webhook signatures
# (configure in Wompi dashboard → Eventos → "Llave secreta de eventos")
WOMPI_EVENTS_SECRET=

# --- Meta CAPI ---
META_CAPI_ACCESS_TOKEN=
NEXT_PUBLIC_FB_PIXEL_ID=1186091610159088

# --- Resend (transactional email) ---
RESEND_API_KEY=

# --- n8n bot integration ---
# Shared secret. n8n must send `Authorization: Bearer <N8N_API_SECRET>`
# when calling /api/bold/payment-link. Generate a long random string.
N8N_API_SECRET=
